{
	"name": "meteor-react-base-mui",
	"private": true,
	"scripts": {
		"precommit": "pretty-quick --staged",
		"start": "meteor run",
		"docker:dev": "docker compose -f docker-compose.dev.yml up --build",
		"docker:dev:detached": "docker compose -f docker-compose.dev.yml up -d --build",
		"docker:prod": "docker compose -f docker-compose.yml up --build",
		"docker:prod:detached": "docker compose -f docker-compose.yml up -d --build",
		"docker:down": "docker compose -f docker-compose.yml down && docker compose -f docker-compose.dev.yml down",
		"docker:down:volumes": "docker compose -f docker-compose.yml down -v && docker compose -f docker-compose.dev.yml down -v",
		"docker:logs:dev": "docker compose -f docker-compose.dev.yml logs -f",
		"docker:logs:prod": "docker compose -f docker-compose.yml logs -f",
		"test": "meteor test --once --driver-package meteortesting:mocha",
		"test-app": "TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
		"visualize": "meteor --production --extra-packages bundle-visualizer",
		"cypress:gui": "cypress open",
		"cypress:headless": "cypress run"
	},
	"dependencies": {
		"@babel/runtime": "^7.29.2",
		"@date-io/date-fns": "^3.2.1",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.11",
		"@mui/material": "^7.3.11",
		"@mui/x-data-grid": "^8.28.6",
		"@types/quill": "^2.0.14",
		"awesome-notifications": "^3.1.3",
		"babel-loader": "^10.1.1",
		"bcrypt": "^6.0.0",
		"body-parser": "^2.2.2",
		"connect-route": "^0.1.5",
		"cors": "^2.8.6",
		"date-fns": "^4.1.0",
		"idb-keyval": "^6.2.2",
		"jquery": "^4.0.0",
		"later": "^1.2.0",
		"lodash": "^4.18.1",
		"meteor-node-stubs": "^1.2.27",
		"nanoid": "^5.1.11",
		"prop-types": "^15.8.1",
		"quill": "^2.0.3",
		"react": "^19.2.6",
		"react-avatar-editor": "^15.1.0",
		"react-dom": "^19.2.6",
		"react-dropzone": "^15.0.0",
		"react-file-input-previews-base64": "^1.0.8",
		"react-number-format": "^5.4.5",
		"react-router-dom": "^6.30.3",
		"react-sortablejs": "^6.1.4",
		"react-transition-group": "^4.4.5",
		"rxjs": "^7.8.2",
		"sharp": "^0.34.5",
		"sortablejs": "^1.15.7",
		"unidecode": "^1.1.0",
		"webpack": "^5.106.2",
		"zipson": "^0.2.12"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@types/lodash": "^4.17.24",
		"@types/meteor": "^2.9.11",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/sortablejs": "^1.15.9",
		"babel-plugin-import": "^1.13.8",
		"babel-plugin-lodash": "^3.3.4",
		"cypress": "^15.15.0",
		"cypress-cucumber-preprocessor": "^4.3.1",
		"cypress-file-upload": "^5.0.8",
		"cypress-xpath": "^2.0.1",
		"less": "^4.6.4",
		"lint-staged": "^17.0.4",
		"prettier": "^3.8.3",
		"pretty-quick": "^4.2.2",
		"typescript": "^6.0.3"
	},
	"cypress-cucumber-preprocessor": {
		"step_definitions": ".cypress/support/step_definitions/",
		"cucumberJson": {
			"generate": true,
			"outputFolder": ".cypress/cucumber-json",
			"filePrefix": "",
			"fileSuffix": ".cucumber"
		}
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	}
}
